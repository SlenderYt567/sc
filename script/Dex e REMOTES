EggCombo
local v1 = game:GetService("ReplicatedStorage")
local v2 = require(v1.Modules.Libraries.ReplicaController)
local v_u_3 = script.Parent.Amount
v2.ReplicaOfClassCreated("PlayerData", function(p4)
	-- upvalues: (copy) v_u_3
	if p4.Data.EggStreak >= 5000 then
		local v5 = v_u_3
		local v6 = p4.Data.EggStreak
		v5.Text = "Egg Luck Combo: +0.5 (" .. tostring(v6):reverse():gsub("%d%d%d", "%1,"):reverse():gsub("^,", "") .. "/\226\136\158)"
	else
		local v7 = v_u_3
		local v8 = string.format
		local v9 = p4.Data.EggStreak / 500
		local v10 = v8("%g", math.floor(v9) * 2.5)
		local v11 = p4.Data.EggStreak
		local v12 = tostring(v11):reverse():gsub("%d%d%d", "%1,"):reverse():gsub("^,", "")
		local v13 = p4.Data.EggStreak / 500
		local v14 = (math.floor(v13) + 1) * 500
