local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
	Name = "Rebirth Hatchers Hub",
	LoadingTitle = "Rebirth Hatchers",
	LoadingSubtitle = "by Roblox_Lua_Expert",
	ConfigurationSaving = {
		Enabled = true,
		FolderName = nil,
		FileName = "RebirthHatchersConfig"
	},
	Discord = {
		Enabled = false,
		Invite = "",
		RememberJoins = true 
	},
	KeySystem = false
})

local Tabs = {
	Farm = Window:CreateTab("Auto Farm", 4483362458),
	Eggs = Window:CreateTab("Auto Hatch", 4483362458)
}

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")

local Events = ReplicatedStorage:WaitForChild("Events")
local Functions = ReplicatedStorage:WaitForChild("Functions")

-- =================[ VARIABLES ]================= --
local getgenv = getgenv or function() return _G end

getgenv().AutoClick = false
getgenv().AutoHatch = false
getgenv().AutoCollect = false

local selectedEgg = "Basic Egg"
local selectedMode = "Triple"

local EggList = {
	"Basic Egg", "Rare Egg", "Farm Egg", "Desert Egg", 
	"Arctic Egg", "Space Egg", "Forest Egg", "Castle Egg", 
	"Jungle Egg", "Candy Egg", "Angelic Egg", "Brainrot Egg"
}

-- =================[ FUNCTIONS ]================= --
local function AutoClicker()
	task.spawn(function()
		while getgenv().AutoClick do
			pcall(function()
				Events:WaitForChild("Click"):FireServer()
			end)
			task.wait() -- Spam as fast as the task scheduler allows
		end
	end)
end

local function AutoHatcher()
	task.spawn(function()
		while getgenv().AutoHatch do
			pcall(function()
				Functions:WaitForChild("Hatch"):InvokeServer(selectedEgg, selectedMode)
			end)
			task.wait(0.1) -- Delay to handle remote yielding and prevent freezing
		end
	end)
end

local function AutoCollectObjects()
	task.spawn(function()
		while getgenv().AutoCollect do
			pcall(function()
				local char = Players.LocalPlayer.Character
				local hrp = char and char:FindFirstChild("HumanoidRootPart")
				
				if hrp then
					-- Collectables generally spawn inside folders starting with Collectables_ 
					-- and have an attribute OwnerUserId that matches the player.
					for _, folder in pairs(workspace:GetChildren()) do
						if string.match(folder.Name, "^Collectables_") then
							for _, obj in pairs(folder:GetChildren()) do
								if obj:GetAttribute("OwnerUserId") == Players.LocalPlayer.UserId then
									local part = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart")
									if part then
										firetouchinterest(hrp, part, 0)
										firetouchinterest(hrp, part, 1)
									end
								end
							end
						end
					end
				end
			end)
			task.wait(0.2)
		end
	end)
end

-- =================[ UI ELEMENTS ]================= --

Tabs.Farm:CreateToggle({
	Name = "Auto Click",
	CurrentValue = false,
	Flag = "AutoClickToggle",
	Callback = function(Value)
		getgenv().AutoClick = Value
		if Value then
			AutoClicker()
		end
	end,
})

Tabs.Farm:CreateToggle({
	Name = "Auto Collect Orbs/Drops",
	CurrentValue = false,
	Flag = "AutoCollectToggle",
	Callback = function(Value)
		getgenv().AutoCollect = Value
		if Value then
			AutoCollectObjects()
		end
	end,
})

Tabs.Eggs:CreateDropdown({
	Name = "Select Egg",
	Options = EggList,
	CurrentOption = {"Basic Egg"},
	MultipleOptions = false,
	Flag = "EggDropdown",
	Callback = function(Option)
		selectedEgg = Option[1]
	end,
})

Tabs.Eggs:CreateDropdown({
	Name = "Hatch Mode",
	Options = {"Single", "Triple", "Octuple"},
	CurrentOption = {"Triple"},
	MultipleOptions = false,
	Flag = "HatchModeDropdown",
	Callback = function(Option)
		selectedMode = Option[1]
	end,
})

Tabs.Eggs:CreateToggle({
	Name = "Auto Hatch",
	CurrentValue = false,
	Flag = "AutoHatchToggle",
	Callback = function(Value)
		getgenv().AutoHatch = Value
		if Value then
			AutoHatcher()
		end
	end,
})

-- =================[ ANTI AFK ]================= --
Players.LocalPlayer.Idled:Connect(function()
	VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
	task.wait(1)
	VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

Rayfield:LoadConfiguration()
