--[[
    SlenderHub | Universal Loader (V11.5 - Optimized)
    Architect: SlenderHub Systems Expert
    Description: Dynamic game detection, modular/standalone script loading, and multi-path fallback.
]]

--// 1. Loader Configuration
local LoaderConfig = {
    Version = "1.1.5",
    Debug = true,
    LocalMode = true, -- Tries local folder first, then GitHub
    ModulesPath = "https://raw.githubusercontent.com/SlenderYt567/sc/refs/heads/main/",
    ScriptFolder = "script/"
}

--// 2. Full Game Mapping (PlaceId -> File Name)
--    Files are searched in: 1. Local "script/" folder, 2. Local root, 3. GitHub root, 4. GitHub "script/" folder
local GameModules = {
    [120405647949186] = "Royal Hatchers Script",     -- Root (main/premium version)
    [4924922222]      = "Brookhaven script",          -- script/ folder
    [93787311916283]  = "Horse Race",                 -- script/ folder
    [82013336390273]  = "Pickaxe Simulator script",   -- script/ folder
    [75992362647444]  = "Tap simulator",              -- Root
    [76558904092080]  = "The Forge Script",           -- Root
    [109983668079237] = "Steal a Branrot(Premium)",   -- Root
    [107807115409153] = "Bee Tappers Script",         -- GitHub only
    [826437311311]    = "pet simulator 99 script",   -- script/ folder
}

--// 3. UI Singleton Guard
if getgenv().SlenderHubLoaded then
    warn("[SlenderHub] Loader already active.")
    return
end
getgenv().SlenderHubLoaded = true

--// 4. Load SlenderWind UI Library (V11)
local swSuccess, SlenderWind = pcall(function()
    return loadstring(game:HttpGet("https://raw.githubusercontent.com/SlenderYt567/sc/refs/heads/main/SlenderWind.lua"))()
end)

if not swSuccess or not SlenderWind then
    error("[SlenderHub] CRITICAL: Failed to load SlenderWind UI Library!")
    return
end

--// 5. Initialize Window
local Window = SlenderWind.Window({
    Name = "SlenderHub | Universal",
    KeySystem = false,
    Theme = {
        Accent = Color3.fromRGB(0, 255, 128),
    }
})

--// 6. Universal Tab (always visible regardless of game)
local TabUniversal = Window:Tab("Universal")

TabUniversal:Label("--- System Utilities ---")

TabUniversal:Button("CPU Optimizer (Low Render)", "Disables 3D rendering to save resources & remove lag", function()
    game:GetService("RunService"):Set3dRenderingEnabled(false)
    print("[SlenderHub] 3D Rendering Disabled.")
end)

TabUniversal:Button("Restore Rendering", "Re-enables 3D rendering if needed", function()
    game:GetService("RunService"):Set3dRenderingEnabled(true)
    print("[SlenderHub] 3D Rendering Restored.")
end)

TabUniversal:Button("Anti-AFK (Enable)", "Prevents disconnection due to inactivity", function()
    local VirtualUser = game:GetService("VirtualUser")
    game.Players.LocalPlayer.Idled:Connect(function()
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end)
    print("[SlenderHub] Anti-AFK Active.")
end)

TabUniversal:Button("Rejoin Server", "Rejoins the current server instantly", function()
    local TeleportService = game:GetService("TeleportService")
    TeleportService:Teleport(game.PlaceId, game.Players.LocalPlayer)
end)

--// 7. Smart Loading Function
local function LoadModule(moduleName)
    print("[SlenderHub] Searching for: '" .. moduleName .. "'")
    local moduleContent = nil
    local loadSource = ""

    -- Path Priority: local script/ -> local root -> GitHub root -> GitHub script/
    local localPaths = {
        LoaderConfig.ScriptFolder .. moduleName,
        moduleName,
    }
    local remotePaths = {
        LoaderConfig.ModulesPath .. moduleName,
        LoaderConfig.ModulesPath .. LoaderConfig.ScriptFolder .. moduleName,
    }

    -- 1. Try local files first (executor workspace folder)
    if LoaderConfig.LocalMode and readfile then
        for _, path in ipairs(localPaths) do
            local ok, res = pcall(function() return readfile(path) end)
            if ok and res and #res > 0 then
                moduleContent = res
                loadSource = "Local (" .. path .. ")"
                break
            end
        end
    end

    -- 2. Fallback to GitHub
    if not moduleContent then
        for _, url in ipairs(remotePaths) do
            local ok, res = pcall(function() return game:HttpGet(url) end)
            if ok and res and #res > 100 and not res:find("404:") and not res:find("Not Found") then
                moduleContent = res
                loadSource = "GitHub: " .. url
                break
            end
        end
    end

    if not moduleContent then
        return false, "File not found in local folders or GitHub."
    end

    -- Compile the content
    local contentFunc, compileErr = loadstring(moduleContent)
    if not contentFunc then
        return false, "Luau syntax error: " .. tostring(compileErr)
    end

    -- Execute and detect: Module (table with .Init) or Standalone
    local execOk, execResult = pcall(contentFunc)
    if not execOk then
        -- If execution returned error but it's a standalone that ran partially, log it
        warn("[SlenderHub] Script returned error: " .. tostring(execResult))
        return false, "Runtime error: " .. tostring(execResult)
    end

    -- Module pattern: returned a table with an Init function
    if type(execResult) == "table" and type(execResult.Init) == "function" then
        print("[SlenderHub] Module detected. Calling Init()...")
        pcall(function() execResult.Init(Window) end)
        return true, loadSource .. " [Module]"
    end

    -- Standalone pattern: script executed itself
    return true, loadSource .. " [Standalone]"
end

--// 8. Game Detection and Loading
local currentPlaceId = game.PlaceId
local targetModule = GameModules[currentPlaceId]

if targetModule then
    local TabStatus = Window:Tab("Status")
    TabStatus:Label("🎮 Game Detected!")
    TabStatus:Paragraph("Module", targetModule)
    TabStatus:Label("⏳ Loading resources...")

    task.spawn(function()
        task.wait(0.5) -- Small delay for UI to appear
        local ok, source = LoadModule(targetModule)
        if ok then
            TabStatus:Paragraph("✅ Loaded", source)
            print("[SlenderHub] Successfully loaded: " .. source)
        else
            TabStatus:Paragraph("❌ Load Failed", tostring(source))
            TabStatus:Label("Check executor folder or GitHub repository.")
            warn("[SlenderHub] Failed: " .. tostring(source))
        end
    end)
else
    -- Unsupported game tab
    local TabNone = Window:Tab("Unsupported")
    TabNone:Label("⚠️ This game is not currently supported.")
    TabNone:Paragraph("Your PlaceId", tostring(currentPlaceId))
    TabNone:Label("Contact SlenderHub to request support.")
end

print("[SlenderHub] Universal Loader V11.5 initialized. PlaceId: " .. tostring(currentPlaceId))
