--[[
    Pet Simulator 99 - Titanic Booth Sniper (ULTIMATE)
    Baseado na lógica oficial do jogo.
]]

-- Configurações
_G.ZapHubBoothsSniperSettings = _G.ZapHubBoothsSniperSettings or {
    MinimumGems = 3000000000, -- 3 Bilhões
    Items = {},
    Extras = {
        ["TitanicPet"] = {
            {Enabled = true, MaxPrice = 4000000000}, -- 4 Bilhões
        },
    },
    ServerHop = {
        Enabled = true,
        Type = "Normal"
    },
    Webhook = {
        Enabled = false,
        WebhookURL = "",
    },
}

-- Serviços
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")
local Player = Players.LocalPlayer

-- Carregar a Library (conforme o dump fornecido)
local Library = nil
pcall(function()
    Library = require(ReplicatedStorage:WaitForChild("Library"))
end)

-- Funções Auxiliares
local function SendWebhook(msg)
    if _G.ZapHubBoothsSniperSettings.Webhook.Enabled and _G.ZapHubBoothsSniperSettings.Webhook.WebhookURL ~= "" then
        pcall(function()
            request({
                Url = _G.ZapHubBoothsSniperSettings.Webhook.WebhookURL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode({content = msg})
            })
        end)
    end
end

local function ServerHop()
    if not _G.ZapHubBoothsSniperSettings.ServerHop.Enabled then return end
    print("🚀 Buscando novo servidor...")
    
    local PlaceID = game.PlaceId
    local Servers = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. PlaceID .. "/servers/Public?sortOrder=Desc&limit=100"))
    
    for _, s in pairs(Servers.data) do
        if s.playing < s.maxPlayers and s.id ~= game.JobId then
            TeleportService:TeleportToPlaceInstance(PlaceID, s.id, Player)
            break
        end
    end
end

-- Lógica de Compra (Baseada no dump: Booths_RequestPurchase)
local function PurchaseItem(ownerID, itemUID, price)
    print("🛒 Tentando comprar item de: " .. tostring(ownerID))
    
    -- No dump vimos que a compra usa Booths_RequestPurchase
    -- Parametros: ownerID, itemTable, scannerValue
    local success, result = pcall(function()
        return Library.Network.Invoke("Booths_RequestPurchase", ownerID, {[itemUID] = 1}, -1)
    end)
    
    if success and result then
        warn("✅ TITANIC COMPRADO POR: " .. price)
        SendWebhook("🚀 Titanic comprado por " .. price .. " diamantes!")
        return true
    end
    print("❌ Falha na compra: " .. tostring(result))
    return false
end

-- Scanner (Baseado no dump)
local function ScanBooths()
    print("📡 Iniciando varredura de booths...")
    
    -- Tenta pegar todas as listagens (GetAllListings)
    local success, allListings = pcall(function()
        return Library.Network.Invoke("Booths_GetAllListings")
    end)
    
    if not success or not allListings then
        warn("⚠️ Falha ao obter listagens. Tentando próximo servidor...")
        ServerHop()
        return
    end

    local titanicConfig = _G.ZapHubBoothsSniperSettings.Extras["TitanicPet"][1]

    for playerID, listings in pairs(allListings) do
        for itemUID, itemData in pairs(listings) do
            local itemName = tostring(itemData.Item.id or "")
            local itemPrice = tonumber(itemData.DiamondCost or itemData.Price) or 0
            
            -- Verificação de Titanic
            if string.find(itemName:lower(), "titanic") and titanicConfig.Enabled then
                if itemPrice <= titanicConfig.MaxPrice and itemPrice >= _G.ZapHubBoothsSniperSettings.MinimumGems then
                    print("💎 Titanic Detectado: " .. itemName .. " | Preço: " .. itemPrice)
                    PurchaseItem(playerID, itemUID, itemPrice)
                end
            end
        end
    end
    
    task.wait(1)
    print("✅ Varredura finalizada. Trocando de servidor...")
    ServerHop()
end

-- Inicialização
if not game:IsLoaded() then game.Loaded:Wait() end

-- Verificar se está na Plaza
if game.PlaceId == 15502339080 or game.PlaceId == 15588442388 then
    print("📍 Plaza detectada. Aguardando carregamento dos módulos...")
    
    local retries = 0
    while not (Library and Library.Network) and retries < 40 do
        pcall(function() Library = require(ReplicatedStorage.Library) end)
        retries = retries + 1
        task.wait(1)
    end
    
    if Library and Library.Network then
        print("🚀 Sistema pronto. Começando caça aos Titanics...")
        task.wait(3)
        ScanBooths()
    else
        warn("❌ Erro ao carregar módulos. Pulando servidor...")
        ServerHop()
    end
else
    print("❌ Script só funciona na Trading Plaza.")
end
