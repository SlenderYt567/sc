--!strict
--[[
    SlenderHub | Universal Loader (V14.0)
    Flow:
        [1] Verify key via SlenderHub API
        [2] Save key locally
        [3] Auto-login on next execution
        [4] Load protected script via SlenderHub loader
]]

--// ==============================[ SERVICES ]============================== //--
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TeleportService = game:GetService("TeleportService")
local MarketplaceService = game:GetService("MarketplaceService")
local RbxAnalyticsService = game:GetService("RbxAnalyticsService")

local LocalPlayer = Players.LocalPlayer
local CurrentPlaceId = game.PlaceId

--// ==============================[ CONFIG ]============================== //--
local Config = {
    FOLDER = "SlenderHub_Universal",
    FILE = "KeyData_" .. LocalPlayer.UserId .. ".json",
    VERIFY_URL = "https://www.slenderhub.shop/api/keys/verify",
    LOADER_URL = "https://www.slenderhub.shop/api/scripts/loader",
    SHOP_URL = "https://slenderhub.shop/",
}

local FILE_PATH = Config.FOLDER .. "/" .. Config.FILE

--// ==============================[ GAME MAPPING ]============================== //--
-- Troque scriptId pelos IDs reais do Script Manager
local GameModules = {
    [120405647949186] = {
        name = "Royal Hatchers Script",
        scriptId = "cc5d4ff1-f602-4eb5-964b-c02d9982f6b6&key"
    },
    [4924922222] = {
        name = "Brookhaven script",
        scriptId = "COLOQUE_O_ID_REAL_DO_SCRIPT"
    },
    [93787311916283] = {
        name = "Horse Race",
        scriptId = "COLOQUE_O_ID_REAL_DO_SCRIPT"
    },
    [82013336390273] = {
        name = "Pickaxe Simulator script",
        scriptId = "COLOQUE_O_ID_REAL_DO_SCRIPT"
    },
    [75992362647444] = {
        name = "Tap simulator",
        scriptId = "COLOQUE_O_ID_REAL_DO_SCRIPT"
    },
    [76558904092080] = {
        name = "The Forge Script",
        scriptId = "COLOQUE_O_ID_REAL_DO_SCRIPT"
    },
    [109983668079237] = {
        name = "Steal a Branrot(Premium)",
        scriptId = "COLOQUE_O_ID_REAL_DO_SCRIPT"
    },
    [107807115409153] = {
        name = "Bee Tappers Script",
        scriptId = "COLOQUE_O_ID_REAL_DO_SCRIPT"
    },
    [826437311311] = {
        name = "pet simulator 99 script",
        scriptId = "COLOQUE_O_ID_REAL_DO_SCRIPT"
    },
}

--// ==============================[ STATE ]============================== //--
local isAccessAuthorized = false
local authorizedKeyType = "basic"
local authorizedDuration = math.huge
local savedLicenseKey = ""

--// ==============================[ SINGLETON GUARD ]============================== //--
if getgenv().SlenderHubLoaded then
    warn("[SlenderHub] Loader already active.")
    return
end
getgenv().SlenderHubLoaded = true

--// ==============================[ LOAD UI LIBRARY ]============================== //--
local swOk, SlenderWind = pcall(function()
    return loadstring(game:HttpGet("https://raw.githubusercontent.com/SlenderYt567/sc/refs/heads/main/SlenderWind.lua"))()
end)

if not swOk or not SlenderWind then
    error("[SlenderHub] CRITICAL: Failed to load SlenderWind!")
    return
end

--// ==============================[ WINDOW ]============================== //--
local Window = SlenderWind.Window({
    Name = "Slender Hub | Universal",
    KeySystem = false,
    Theme = { Accent = Color3.fromRGB(0, 255, 128) }
})

--// ==============================[ HELPERS ]============================== //--
local function Notify(title: string, text: string, nType: string?, duration: number?)
    pcall(function()
        Window:Notify(title, text, duration or 5, nType or "Success")
    end)
end

local function formatTime(seconds: number): string
    if seconds == math.huge then
        return "Lifetime"
    end

    local d = math.floor(seconds / 86400)
    local h = math.floor((seconds % 86400) / 3600)
    local m = math.floor((seconds % 3600) / 60)
    return string.format("%dd %02dh %02dm", d, h, m)
end

local function getHWID(): string
    local ok, hwid = pcall(function()
        return RbxAnalyticsService:GetClientId()
    end)
    return ok and hwid or "UNKNOWN_HWID"
end

local function getGameInfo()
    return GameModules[CurrentPlaceId]
end

--// ==============================[ KEY STORAGE ]============================== //--
local function saveKey(keyType: string, key: string, duration: number)
    if not isfolder(Config.FOLDER) then
        makefolder(Config.FOLDER)
    end

    writefile(FILE_PATH, HttpService:JSONEncode({
        Type = keyType,
        Key = key,
        Time = workspace:GetServerTimeNow(),
        CustomDuration = duration,
    }))
end

local function clearSavedKey()
    if isfile(FILE_PATH) then
        pcall(function()
            delfile(FILE_PATH)
        end)
    end
end

local function checkLocalKey(): (boolean, any, number?)
    if not isfile(FILE_PATH) then
        return false, nil
    end

    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(FILE_PATH))
    end)

    if not ok or not data or not data.Time then
        clearSavedKey()
        return false, nil
    end

    local dur = data.CustomDuration or math.huge
    if dur == math.huge then
        return true, data, math.huge
    end

    local elapsed = workspace:GetServerTimeNow() - data.Time
    if elapsed > dur then
        clearSavedKey()
        return false, nil
    end

    return true, data, (dur - elapsed)
end

--// ==============================[ API ]============================== //--
local function verifySlenderHubKey(inputKey: string): (boolean, string?, number?, string?)
    local hwid = getHWID()
    local url = Config.VERIFY_URL
        .. "?key=" .. HttpService:UrlEncode(inputKey)
        .. "&hwid=" .. HttpService:UrlEncode(hwid)

    local ok, response = pcall(function()
        return HttpService:GetAsync(url)
    end)

    if not ok or not response then
        return false, nil, nil, "HTTP request failed during verification."
    end

    local decodeOk, data = pcall(function()
        return HttpService:JSONDecode(response)
    end)

    if not decodeOk or not data then
        return false, nil, nil, "Failed to parse verification response."
    end

    if not data.success then
        return false, nil, nil, tostring(data.message or "Key invalid.")
    end

    local keyType = tostring((data.data and data.data.tier) or data.tier or "basic")
    local duration = math.huge

    local expiresRaw = (data.data and data.data.expires) or data.expires_at
    if type(expiresRaw) == "string" and expiresRaw ~= "" then
        -- Se quiser, depois dá para trocar por parsing real de ISO date
        duration = math.huge
    end

    return true, keyType, duration, nil
end

local function loadGameScriptViaSlenderHub(licenseKey: string): boolean
    local gameInfo = getGameInfo()
    if not gameInfo then
        warn("[SlenderHub] No mapped script for this game.")
        return false
    end

    if not gameInfo.scriptId or gameInfo.scriptId == "" or gameInfo.scriptId == "COLOQUE_O_ID_REAL_DO_SCRIPT" then
        Notify("Error", "scriptId not configured for this game.", "Error", 5)
        warn("[SlenderHub] Missing scriptId for PlaceId: " .. tostring(CurrentPlaceId))
        return false
    end

    local hwid = getHWID()
    local loaderUrl = Config.LOADER_URL
        .. "?script_id=" .. HttpService:UrlEncode(gameInfo.scriptId)
        .. "&key=" .. HttpService:UrlEncode(licenseKey)
        .. "&hwid=" .. HttpService:UrlEncode(hwid)

    local ok, err = pcall(function()
        loadstring(game:HttpGet(loaderUrl))()
    end)

    if not ok then
        warn("[SlenderHub] Loader endpoint failed: " .. tostring(err))
        return false
    end

    return true
end

--// ==============================[ LOAD FLOW ]============================== //--
local function loadGameScript(accessLevel: string)
    local gameInfo = getGameInfo()
    if not gameInfo then
        Notify("SlenderHub", "Game not supported (PlaceId: " .. tostring(CurrentPlaceId) .. ")", "Error")
        return
    end

    if getgenv then
        getgenv().SlenderHubAccessLevel = accessLevel
    else
        _G.SlenderHubAccessLevel = accessLevel
    end

    if savedLicenseKey == "" then
        Notify("Error", "No saved license key in memory.", "Error", 4)
        return
    end

    Notify("Loading...", "Connecting to SlenderHub loader...", "Success", 2)

    local loaderOk = loadGameScriptViaSlenderHub(savedLicenseKey)
    if loaderOk then
        Notify("Loaded", "Game script launched via SlenderHub loader.", "Success", 4)
        print("[SlenderHub] Launched via protected loader: " .. gameInfo.name)
        return
    end

    Notify("Error", "Protected loader failed.", "Error", 4)
end

--// ==============================[ AUTO LOGIN ]============================== //--
local isSaved, savedData, remainingTime = checkLocalKey()

if isSaved and savedData then
    isAccessAuthorized = true
    authorizedKeyType = savedData.Type or "basic"
    authorizedDuration = savedData.CustomDuration or math.huge
    savedLicenseKey = savedData.Key or ""

    local timeMsg = (remainingTime == math.huge) and "Lifetime Access" or formatTime(remainingTime)
    Notify("Auto-Login", "Welcome back! Remaining: " .. timeMsg, "Success", 3)
    task.wait(0.5)
    loadGameScript(authorizedKeyType)
    return
end

--// ==============================[ AUTH TAB ]============================== //--
local TabAuth = Window:Tab("Authentication")

local gameName = "Unknown Game"
pcall(function()
    gameName = MarketplaceService:GetProductInfo(CurrentPlaceId).Name
end)

local mappedGame = getGameInfo()
local statusText = mappedGame
    and ("Supported: " .. gameName)
    or ("Not Supported (PlaceId: " .. tostring(CurrentPlaceId) .. ")")

TabAuth:Paragraph("Game Status", statusText)
TabAuth:Label("── Key Methods ──")
TabAuth:Section("SlenderHub Key")

TabAuth:Input("License Key", "SLENDER-XXXX-XXXX-XXXX", "SlenderKeyInput", "Paste your SlenderHub key", function(text)
    local key = text:gsub("%s+", "")
    if #key < 5 then
        return
    end

    Notify("Checking...", "Verifying your SlenderHub key...", "Success", 2)

    local valid, keyType, duration, errMsg = verifySlenderHubKey(key)

    if valid and keyType and duration then
        isAccessAuthorized = true
        authorizedKeyType = keyType
        authorizedDuration = duration
        savedLicenseKey = key

        saveKey(keyType, key, duration)

        local durText = (duration == math.huge) and "Lifetime" or formatTime(duration)
        Notify("Key Valid", keyType .. " - " .. durText, "Success", 5)
    else
        isAccessAuthorized = false
        Notify("Invalid Key", errMsg or "Key invalid or HWID not authorized.", "Error", 5)
    end
end)

TabAuth:Button("Buy Key (slenderhub.shop)", "Copies the store link", function()
    setclipboard(Config.SHOP_URL)
    Notify("Copied", "Store link copied to clipboard.", "Success", 3)
end)

TabAuth:Label("── Launch ──")
TabAuth:Button("Launch Hub", "Verify and load the protected game script", function()
    if not isAccessAuthorized then
        Notify("Access Denied", "Enter a valid SlenderHub key first.", "Error", 4)
        return
    end

    if not getGameInfo() then
        Notify("Error", "Game not supported yet.", "Error", 3)
        return
    end

    local durText = (authorizedDuration == math.huge) and "Lifetime" or formatTime(authorizedDuration)
    Notify("Loading...", authorizedKeyType .. " Access - " .. durText, "Success", 2)
    task.wait(0.5)
    loadGameScript(authorizedKeyType)
end)

--// ==============================[ UNIVERSAL TAB ]============================== //--
local TabUniversal = Window:Tab("Universal")

TabUniversal:Label("--- Performance ---")
TabUniversal:Button("CPU Optimizer (Low Render)", "Disables 3D rendering to reduce lag", function()
    RunService:Set3dRenderingEnabled(false)
    Notify("Optimizer", "3D rendering disabled.", "Success", 3)
end)

TabUniversal:Button("Restore Rendering", "Re-enables 3D rendering", function()
    RunService:Set3dRenderingEnabled(true)
    Notify("Optimizer", "Rendering restored.", "Success", 3)
end)

TabUniversal:Button("Anti-AFK (Enable)", "Prevents disconnection from inactivity", function()
    local VirtualUser = game:GetService("VirtualUser")
    LocalPlayer.Idled:Connect(function()
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end)
    Notify("Anti-AFK", "Active! You won't be kicked.", "Success", 3)
end)

TabUniversal:Button("Rejoin Server", "Teleports you back into the game", function()
    TeleportService:Teleport(CurrentPlaceId, LocalPlayer)
end)

TabUniversal:Label("--- Account ---")
TabUniversal:Button("Reset Saved Key", "Deletes the saved key locally", function()
    if isfile(FILE_PATH) then
        clearSavedKey()
        savedLicenseKey = ""
        isAccessAuthorized = false
        Notify("Key Reset", "Saved key removed. Re-execute the script.", "Success", 5)
    else
        Notify("Error", "No saved key found.", "Error", 5)
    end
end)

print("[SlenderHub] Universal V14.0 loaded. PlaceId: " .. tostring(CurrentPlaceId))
