--[[
    Pet Simulator 99 - Titanic Booth Sniper (ULTIMATE V2)
    Baseado na lógica oficial do jogo.
]]

-- Configurações
_G.ZapHubBoothsSniperSettings = _G.ZapHubBoothsSniperSettings or {
    MinimumGems = 3000000000, -- 3 Bilhões
    Items = {},
    Extras = {
        ["TitanicPet"] = {
            {Enabled = true, MaxPrice = 4500000000}, -- 5 Bilhões (Aumentado conforme console)
        },
    },
    ServerHop = {
        Enabled = true,
        Type = "Normal"
    },
    Webhook = {
        Enabled = false,
        WebhookURL = "",
    },
}

-- Serviços
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")
local Player = Players.LocalPlayer

-- Carregar Módulos (Tentativa mais leve e compatível)
local Network = nil
local function GetNetwork()
    -- Tenta pegar de variáveis globais (outros scripts podem ter carregado)
    if getgenv and getgenv().Network then return getgenv().Network end
    if _G.Network then return _G.Network end
    
    -- Tenta caminhos comuns
    local paths = {
        ReplicatedStorage:FindFirstChild("Library") and ReplicatedStorage.Library:FindFirstChild("Client") and ReplicatedStorage.Library.Client:FindFirstChild("Network"),
        ReplicatedStorage:FindFirstChild("Network")
    }
    
    for _, path in pairs(paths) do
        if path and path:IsA("ModuleScript") then
            local s, res = pcall(require, path)
            if s and res then return res end
        end
    end
    
    -- Tenta pela Library principal se tudo falhar
    local s, lib = pcall(require, ReplicatedStorage:FindFirstChild("Library"))
    if s and lib and lib.Network then return lib.Network end
    
    return nil
end

Network = GetNetwork()

-- Funções Auxiliares
local function SendWebhook(msg)
    if _G.ZapHubBoothsSniperSettings.Webhook.Enabled and _G.ZapHubBoothsSniperSettings.Webhook.WebhookURL ~= "" then
        pcall(function()
            request({
                Url = _G.ZapHubBoothsSniperSettings.Webhook.WebhookURL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode({content = msg})
            })
        end)
    end
end

local function ServerHop()
    if not _G.ZapHubBoothsSniperSettings.ServerHop.Enabled then return end
    print("🚀 Tentando trocar de servidor (Ignorando Anti-Scam)...")
    
    local PlaceID = game.PlaceId
    
    -- Tenta usar a Remote de teleporte do próprio jogo se disponível
    pcall(function()
        if Network then
            Network.Invoke("TradingBooth_RequestTradingPlaza")
        end
    end)
    
    task.wait(1)
    
    -- Fallback para TeleportService padrão
    local Servers = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. PlaceID .. "/servers/Public?sortOrder=Desc&limit=100"))
    for _, s in pairs(Servers.data) do
        if s.playing < s.maxPlayers and s.id ~= game.JobId then
            TeleportService:TeleportToPlaceInstance(PlaceID, s.id, Player)
            break
        end
    end
end

-- Lógica de Compra (Baseada no dump: Booths_RequestPurchase)
local function PurchaseItem(ownerID, itemUID, price)
    print("🛒 Tentando comprar de " .. tostring(ownerID))
    
    local success, result = pcall(function()
        return Network.Invoke("Booths_RequestPurchase", ownerID, {[itemUID] = 1}, -1)
    end)
    
    if success and result then
        warn("✅ TITANIC COMPRADO POR: " .. price)
        SendWebhook("🚀 Titanic comprado por " .. price .. " diamantes!")
        return true
    end
    print("❌ Falha na compra: " .. tostring(result))
    return false
end

-- Scanner
local function ScanBooths()
    print("📡 Iniciando varredura...")
    
    local success, allListings = pcall(function()
        return Network.Invoke("Booths_GetAllListings")
    end)
    
    if not success or not allListings then
        warn("⚠️ Falha ao obter listagens. Pulando servidor...")
        ServerHop()
        return
    end

    local titanicConfig = _G.ZapHubBoothsSniperSettings.Extras["TitanicPet"][1]

    for playerID, listings in pairs(allListings) do
        for itemUID, itemData in pairs(listings) do
            local itemName = tostring(itemData.Item.id or "")
            local itemPrice = tonumber(itemData.DiamondCost or itemData.Price) or 0
            
            if string.find(itemName:lower(), "titanic") and titanicConfig.Enabled then
                if itemPrice <= titanicConfig.MaxPrice and itemPrice >= _G.ZapHubBoothsSniperSettings.MinimumGems then
                    print("💎 Titanic Detectado: " .. itemName .. " | Preço: " .. itemPrice)
                    PurchaseItem(playerID, itemUID, itemPrice)
                end
            end
        end
    end
    
    task.wait(1)
    print("✅ Varredura finalizada. Próximo servidor...")
    ServerHop()
end

-- Inicialização
if not game:IsLoaded() then game.Loaded:Wait() end

if game.PlaceId == 15502339080 or game.PlaceId == 15588442388 then
    print("📍 Plaza detectada. Carregando rede...")
    
    local retries = 0
    while not (Network and Network.Invoke) and retries < 40 do
        Network = GetNetwork()
        retries = retries + 1
        task.wait(1)
        if retries % 5 == 0 then print("⏳ Tentando carregar rede... (" .. retries .. "/40)") end
    end
    
    if Network and Network.Invoke then
        print("🚀 Rede carregada com sucesso!")
        task.wait(2)
        ScanBooths()
    else
        warn("❌ Falha crítica na rede. Trocando de servidor...")
        ServerHop()
    end
else
    print("❌ Use este script apenas na Trading Plaza.")
end
