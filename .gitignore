--// ======= [METHOD 1] VELINK KEY =======
TabAuth:Section("🔗 Velink Key (Free 24h / Premium)")
TabAuth:Input("Velink Key", "VELINK-XXXX-XXXX", "VelinkInput", "Paste your Velink key", function(text)
    local key = text:gsub("%s+", "")
    if #key < 5 then return end

    Notify("Checking...", "Verifying Velink key...", "Success", 2)

    local keyType, duration = verifyVelinkKey(key)
    if keyType and duration then
        isAccessAuthorized = true
        authorizedKeyType  = keyType
        authorizedDuration = duration
        saveKey(keyType, key, duration)
        local durText = (duration == math.huge) and "Lifetime" or formatTime(duration)
        Notify("✅ Velink Valid!", keyType .. " Key — " .. durText, "Success", 5)
    else
        isAccessAuthorized = false
        Notify("❌ Invalid Key", "Expired or not found in Velink.", "Error", 4)
    end
end)

TabAuth:Button("🔑 Get Free Key (Velink - 24h)", "Opens the Velink unlock link", function()
    setclipboard(Config.FREE_KEY_LINK)
    Notify("Copied!", "Velink free key link copied to clipboard.", "Success", 3)
end)

--// ======= [METHOD 2] SLENDERKEY =======
TabAuth:Section("💎 SlenderKey (slenderhub.shop)")
TabAuth:Input("SlenderKey", "SLENDER-XXXX-XXXX", "SlenderKeyInput", "Paste your SlenderKey", function(text)
    local key = text:gsub("%s+", "")
    if #key < 5 then return end

    Notify("Checking...", "Verifying SlenderKey...", "Success", 2)

    local keyType, duration, extra = verifySlenderKey(key)
    if keyType and duration then
        isAccessAuthorized = true
        authorizedKeyType  = keyType
        authorizedDuration = duration
        saveKey(keyType, key, duration)
        local durText = (duration == math.huge) and "Lifetime" or formatTime(duration)
        Notify("✅ SlenderKey Valid!", keyType .. " — " .. durText, "Success", 5)
    else
        isAccessAuthorized = false
        Notify("❌ Denied", tostring(extra or "Invalid SlenderKey."), "Error", 4)
    end
end)

TabAuth:Button("💎 Buy Premium (SlenderHub.shop)", "Opens the SlenderHub shop link", function()
    setclipboard(Config.SHOP_URL)
    Notify("Copied!", "Shop link copied to clipboard.", "Success", 3)
end)

--// ======= LAUNCH BUTTON =======
TabAuth:Label("── Launch ──")
TabAuth:Button("🚀 Launch Hub", "Verify and load the game script", function()
    if not isAccessAuthorized then
        Notify("Access Denied", "Enter a valid Velink or SlenderKey first.", "Error", 4)
        return
    end
    if not GameModules[CurrentPlaceId] then
        Notify("Error", "Game not supported yet.", "Error", 3)
        return
    end

    local durText = (authorizedDuration == math.huge) and "Lifetime" or formatTime(authorizedDuration)
    Notify("Loading...", authorizedKeyType .. " Access — " .. durText, "Success", 2)
    task.wait(0.5)
    loadGameScript(authorizedKeyType)
end)

