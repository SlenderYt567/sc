--!strict
--[[
    SlenderHub | Universal Loader (V13.0 - SlenderHub Global Key System)
    Architect: SlenderHub Systems Expert
    Key System:
        [1] SlenderHub Global Keys - Free and Premium via slenderhub.shop
        API: https://www.slenderhub.shop/api/keys/verify
        Claim Page: https://www.slenderhub.shop/#/claim
]]

--// ==============================[ SERVICES ]============================== //--
local HttpService    = game:GetService("HttpService")
local Analytics      = game:GetService("RbxAnalyticsService")
local Players        = game:GetService("Players")
local StarterGui     = game:GetService("StarterGui")
local RunService     = game:GetService("RunService")
local CoreGui        = game:GetService("CoreGui")
local LocalPlayer    = Players.LocalPlayer
local CurrentPlaceId = game.PlaceId

--// ==============================[ CONFIG ]============================== //--
local Config = {
    -- Storage
    FOLDER        = "SlenderHub_Universal",
    KEY_FILE      = "SlenderHubKey.json",
    -- SlenderHub Key API
    VERIFY_URL    = "https://www.slenderhub.shop/api/keys/verify",
    CLAIM_URL     = "https://www.slenderhub.shop/#/claim?owner=SlenderYt567&duration=1&prefix=SLENDER&note=Free+claim",
    SHOP_URL      = "https://www.slenderhub.shop/",
}

local KEY_FILE_PATH      = Config.FOLDER .. "/" .. Config.KEY_FILE
local isAccessAuthorized = false
local authorizedKeyType  = "free"
local authorizedTier     = "free"

--// ==============================[ GAME MAPPING ]============================== //--
local GameModules = {
    [120405647949186] = "Royal Hatchers Script",
    [4924922222]      = "Brookhaven script",
    [93787311916283]  = "Horse Race",
    [82013336390273]  = "Pickaxe Simulator script",
    [75992362647444]  = "Tap simulator",
    [76558904092080]  = "The Forge Script",
    [109983668079237] = "Steal a Branrot(Premium)",
    [107807115409153] = "Bee Tappers Script",
    [826437311311]    = "pet simulator 99 script",
}

--// ==============================[ SINGLETON GUARD ]============================== //--
if getgenv().SlenderHubLoaded then
    warn("[SlenderHub] Loader already active.")
    return
end
getgenv().SlenderHubLoaded = true

--// ==============================[ LOAD UI LIBRARY ]============================== //--
local swOk, SlenderWind = pcall(function()
    return loadstring(game:HttpGet("https://raw.githubusercontent.com/SlenderYt567/sc/refs/heads/main/SlenderWind.lua"))()
end)
if not swOk or not SlenderWind then
    error("[SlenderHub] CRITICAL: Failed to load SlenderWind!")
    return
end

--// ==============================[ WINDOW ]============================== //--
local Window = SlenderWind.Window({
    Name      = "Slender Hub | Universal",
    KeySystem = false,
    Theme     = { Accent = Color3.fromRGB(0, 255, 128) }
})

--// ==============================[ HELPERS ]============================== //--
local function Notify(title: string, text: string, nType: string?, duration: number?)
    pcall(function()
        Window:Notify(title, text, duration or 5, nType or "Success")
    end)
end

local function formatTime(seconds: number): string
    if seconds == math.huge then return "Lifetime" end
    local d = math.floor(seconds / 86400)
    local h = math.floor((seconds % 86400) / 3600)
    local m = math.floor((seconds % 3600) / 60)
    return string.format("%dd %02dh %02dm", d, h, m)
end

--// ==============================[ HWID ]============================== //--
local function getHWID(): string
    local ok, hwid = pcall(function()
        return Analytics:GetClientId()
    end)
    return ok and hwid or "UNKNOWN_HWID"
end

--// ==============================[ KEY STORAGE ]============================== //--
local function saveGlobalKey(key: string)
    pcall(function()
        if not isfolder(Config.FOLDER) then makefolder(Config.FOLDER) end
        writefile(KEY_FILE_PATH, HttpService:JSONEncode({ key = key }))
    end)
end

local function loadSavedKey(): string?
    if not isfile or not isfile(KEY_FILE_PATH) then return nil end
    local ok, parsed = pcall(function()
        return HttpService:JSONDecode(readfile(KEY_FILE_PATH))
    end)
    if ok and parsed and parsed.key then
        return parsed.key
    end
    return nil
end

local function deleteSavedKey()
    pcall(function()
        if isfile and isfile(KEY_FILE_PATH) then
            delfile(KEY_FILE_PATH)
        end
    end)
end

--// ==============================[ SLENDERHUB KEY VERIFY ]============================== //--
local function verifyKey(licenseKey: string): (boolean, any)
    local hwid = getHWID()
    local url = Config.VERIFY_URL
        .. "?key=" .. HttpService:UrlEncode(licenseKey)
        .. "&hwid=" .. HttpService:UrlEncode(hwid)

    local ok, response = pcall(function()
        return game:HttpGet(url)
    end)

    if not ok then
        warn("[SlenderHub] verify request failed: " .. tostring(response))
        return false, "Request failed"
    end

    local decodeOk, data = pcall(function()
        return HttpService:JSONDecode(response)
    end)

    if not decodeOk or not data then
        warn("[SlenderHub] Failed to decode verify response.")
        return false, "Decode error"
    end

    if not data.success then
        return false, data.message or "Invalid key"
    end

    return true, data
end

local function authenticateWithKey(licenseKey: string): boolean
    local ok, valid, payload = pcall(function()
        return verifyKey(licenseKey)
    end)

    if not ok then
        warn("[SlenderHub] Authentication error: " .. tostring(valid))
        return false
    end

    if not valid then
        warn("[SlenderHub] Invalid key: " .. tostring(payload))
        return false
    end

    saveGlobalKey(licenseKey)

    local tier = payload.tier or payload.type or "free"
    authorizedTier     = tier
    authorizedKeyType  = tier
    isAccessAuthorized = true

    print("[SlenderHub] Authenticated with tier:", tier)
    return true
end

--// ==============================[ GAME SCRIPT LOADER ]============================== //--
local LoaderConfig = {
    ModulesPath  = "https://raw.githubusercontent.com/SlenderYt567/sc/refs/heads/main/",
    ScriptFolder = "script/"
}

local function loadGameScript(accessLevel: string)
    local targetFile = GameModules[CurrentPlaceId]
    if not targetFile then
        Notify("SlenderHub", "Game not supported (PlaceId: " .. CurrentPlaceId .. ")", "Error")
        return
    end

    -- Set global access level for game scripts to read
    if getgenv then
        getgenv().SlenderHubAccessLevel = accessLevel
    else
        _G.SlenderHubAccessLevel = accessLevel
    end

    local moduleContent = nil
    local loadSource    = ""

    -- Local search first
    if readfile then
        for _, path in ipairs({LoaderConfig.ScriptFolder .. targetFile, targetFile}) do
            local lok, res = pcall(function() return readfile(path) end)
            if lok and res and #res > 0 then
                moduleContent = res
                loadSource    = "Local"
                break
            end
        end
    end

    -- GitHub fallback (URL-encode spaces)
    if not moduleContent then
        local encoded = targetFile:gsub(" ", "%%20")
        for _, url in ipairs({
            LoaderConfig.ModulesPath .. encoded,
            LoaderConfig.ModulesPath .. LoaderConfig.ScriptFolder .. encoded,
        }) do
            local gok, res = pcall(function() return game:HttpGet(url) end)
            if gok and res and #res > 100 and not res:find("404") and not res:find("<html") then
                moduleContent = res
                loadSource    = "GitHub"
                break
            end
        end
    end

    if not moduleContent then
        Notify("Error", "Failed to find game script!", "Error")
        return
    end

    -- Execute
    local func, err = loadstring(moduleContent)
    if not func then
        Notify("Error", "Script compile error: " .. tostring(err), "Error")
        return
    end

    local execOk, result = pcall(func)
    if execOk and type(result) == "table" and type(result.Init) == "function" then
        pcall(function() result.Init(Window) end)
    end

    Notify("Loaded", "Game script launched from " .. loadSource, "Success")
    print("[SlenderHub] Launched: " .. targetFile .. " via " .. loadSource)
end

--// ==============================[ AUTO-LOGIN CHECK ]============================== //--
local rememberedKey = loadSavedKey()

if rememberedKey then
    print("[SlenderHub] Found saved key, verifying...")
    Notify("Auto-Login", "Verifying saved key...", "Success", 2)
    task.wait(0.5)

    if authenticateWithKey(rememberedKey) then
        local tierLabel = authorizedTier:sub(1,1):upper() .. authorizedTier:sub(2)
        Notify("Auto-Login", "Welcome back! Tier: " .. tierLabel, "Success", 3)
        task.wait(0.5)
        loadGameScript(authorizedTier)
        return
    else
        -- Saved key is invalid/expired, remove it
        deleteSavedKey()
        Notify("Session Expired", "Saved key is no longer valid. Please enter a new key.", "Error", 4)
    end
end

--// ==============================[ AUTHENTICATION TAB ]============================== //--
local TabAuth = Window:Tab("Authentication")

-- Game Status Info
local gameName = "Unknown Game"
pcall(function()
    gameName = game:GetService("MarketplaceService"):GetProductInfo(CurrentPlaceId).Name
end)
local statusText = GameModules[CurrentPlaceId]
    and ("✅ Supported: " .. gameName)
    or  ("⚠️ Not Supported (PlaceId: " .. CurrentPlaceId .. ")")
