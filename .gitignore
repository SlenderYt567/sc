    local tierLabel = authorizedTier:sub(1,1):upper() .. authorizedTier:sub(2)
    Notify("Loading...", "Tier: " .. tierLabel, "Success", 2)
    task.wait(0.5)
    loadGameScript(authorizedTier)
end)

