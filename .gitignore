--// ==============================[ MAIN FEATURES ]============================== //--
TabMain:Section("👊 Training")
TabMain:Dropdown("Punch Method", {"Remote", "Click"}, "PunchMethod", "Remote", function(val)
    Settings.PunchMethod = val
end)

TabMain:Toggle("Auto Punch", "Automatically punches for damage", function(state)
    Flags.AutoPunch = state
    if state then
        task.spawn(function()
            while Flags.AutoPunch do
                pcall(function()
                    if Settings.PunchMethod == "Remote" then
                        game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("DamageIncreaseOnClickEvent"):FireServer()
                    else
                        VirtualUser:CaptureController()
                        VirtualUser:ClickButton1(Vector2.new(9999, 9999))
                    end
                end)
                task.wait()
            end
        end)
    end
end)

TabMain:Toggle("Auto Ascension", "Automatically ascends when ready", function(state)
    Flags.AutoAscend = state
    if state then
        task.spawn(function()
            while Flags.AutoAscend do
                Events.AscendEvent:FireServer(true)
                task.wait(5)
            end
        end)
    end
end)

TabMain:Toggle("Auto Achievements", "Automatically claims rewards every minute", function(state)
    Flags.AutoAchievements = state
    if state then
        task.spawn(function()
            while Flags.AutoAchievements do
                local ClaimEvent = Events:FindFirstChild("ClaimAchievement")
                if ClaimEvent then
                    local info = ClaimEvent:InvokeServer("Info")
                    if info then
                        for id, data in pairs(info) do
                            if data.progress >= 1 and data.progress ~= 2 then
                                ClaimEvent:InvokeServer("Claim", id)
                            end
                        end
                    end
                end
                task.wait(60)
            end
        end)
    end
end)

