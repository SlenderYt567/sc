--// ==============================[ INITIALIZATION ]============================== //--
local function Init()
    local ok, data, remain = checkLocalKey()
    if ok then
        isAccessAuthorized = true; authorizedKeyType = data.Type; authorizedDuration = remain;
        Notify("Auto-Login", "Welcome back! " .. authorizedKeyType .. " status active.", "Success")
    end
end

Init()
