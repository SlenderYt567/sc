--[[
    Pet Simulator 99 - Titanic Booth Sniper
    Desenvolvido para SlenderHub
]]

-- Configurações (Exemplo solicitado pelo usuário)
_G.ZapHubBoothsSniperSettings = _G.ZapHubBoothsSniperSettings or {
    MinimumGems = 3000000000, -- 3 Bilhões
    Items = {},
    Extras = {
        ["TitanicPet"] = {
            {Enabled = true, Tier = nil, Shiny = nil, MaxPrice = 4000000000, PercentageProfit = "0", BlackList = {}}, -- 4 Bilhões
        },
        ["HugePet"] = {
            {Enabled = false, Tier = nil, Shiny = nil, MaxPrice = 0, PercentageProfit = "0", BlackList = {}},
        }
    },
    ServerHop = {
        Enabled = true,
        Type = "Normal" -- "Normal", "Pro"
    },
    Webhook = {
        Enabled = false,
        WebhookURL = "",
    },
}

-- Serviços
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")

local Player = Players.LocalPlayer
local Network = ReplicatedStorage:WaitForChild("Network")
local Library = require(ReplicatedStorage.Library)

-- Funções Auxiliares
local function SendWebhook(msg)
    if _G.ZapHubBoothsSniperSettings.Webhook.Enabled and _G.ZapHubBoothsSniperSettings.Webhook.WebhookURL ~= "" then
        pcall(function()
            request({
                Url = _G.ZapHubBoothsSniperSettings.Webhook.WebhookURL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode({content = msg})
            })
        end)
    end
end

local function ServerHop()
    if not _G.ZapHubBoothsSniperSettings.ServerHop.Enabled then return end
    
    local PlaceID = game.PlaceId
    local Servers = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. PlaceID .. "/servers/Public?sortOrder=Desc&limit=100"))
    
    for _, s in pairs(Servers.data) do
        if s.playing < s.maxPlayers and s.id ~= game.JobId then
            TeleportService:TeleportToPlaceInstance(PlaceID, s.id, Player)
            break
        end
    end
end

-- Lógica de Compra
local function PurchaseItem(boothOwnerID, itemUID, price)
    local success, result = Network.TradingBooth_PurchaseItem:InvokeServer(boothOwnerID, itemUID)
    if success then
        warn("!!! ITEM COMPRADO: " .. tostring(itemUID) .. " por " .. tostring(price))
        SendWebhook("🚀 Titanic comprado por " .. tostring(price) .. " diamantes!")
    end
    return success
end

-- Scanner de Booths
local function ScanBooths()
    print("Iniciando scan de booths...")
    local allListings = Network.TradingBooth_GetAllListings:InvokeServer()
    
    for playerID, listings in pairs(allListings) do
        for itemUID, itemData in pairs(listings) do
            local itemName = itemData.Item.id or "Unknown"
            local itemPrice = itemData.Price
            local isTitanic = string.find(itemName:lower(), "titanic")
            
            -- Verificar se é Titanic e está dentro do preço
            local titanicSettings = _G.ZapHubBoothsSniperSettings.Extras["TitanicPet"][1]
            
            if isTitanic and titanicSettings.Enabled then
                if itemPrice <= titanicSettings.MaxPrice and itemPrice >= _G.ZapHubBoothsSniperSettings.MinimumGems then
                    print("Titanic Encontrado! Tentando comprar: " .. itemName .. " por " .. itemPrice)
                    PurchaseItem(playerID, itemUID, itemPrice)
                end
            end
        end
    end
    
    -- Se não encontrou nada ou terminou o scan, server hop
    task.wait(2)
    print("Nenhum item encontrado no critério. Mudando de servidor...")
    ServerHop()
end

-- Inicialização
if game.PlaceId == 15502339080 or game.PlaceId == 15588442388 then -- Trading Plaza IDs
    task.wait(5) -- Esperar carregar
    ScanBooths()
else
    print("Você não está na Trading Plaza. Teleportando...")
    -- Lógica de teleport para Plaza aqui se necessário
    -- Recomenda-se entrar manualmente ou via script de teleport
end
