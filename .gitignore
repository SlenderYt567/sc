TabAuth:Label("── SlenderHub Key System ──")

--// ======= KEY INPUT =======
TabAuth:Section("🔑 Global Key (Free / Premium)")
TabAuth:Input("License Key", "SLENDER-XXXX-XXXX", "KeyInput", "Paste your SlenderHub key here", function(text)
    local key = text:gsub("%s+", "")
    if #key < 5 then return end

    Notify("Verifying...", "Checking your key with SlenderHub...", "Success", 2)
    task.wait(0.5)

    local success = authenticateWithKey(key)
    if success then
        local tierLabel = authorizedTier:sub(1,1):upper() .. authorizedTier:sub(2)
        Notify("✅ Key Valid!", "Tier: " .. tierLabel .. " — Key saved locally.", "Success", 5)
    else
        isAccessAuthorized = false
        Notify("❌ Invalid Key", "Key not found or HWID mismatch. Try again.", "Error", 4)
    end
end)

TabAuth:Button("🎁 Get Free Key (Claim Page)", "Opens the SlenderHub free key claim page", function()
    setclipboard(Config.CLAIM_URL)
    Notify("Copied!", "Claim page URL copied to clipboard. Open it in your browser.", "Success", 3)
end)

TabAuth:Button("💎 Buy Premium (slenderhub.shop)", "Opens the SlenderHub premium shop", function()
    setclipboard(Config.SHOP_URL)
    Notify("Copied!", "Shop link copied to clipboard.", "Success", 3)
end)

--// ======= LAUNCH BUTTON =======
TabAuth:Label("── Launch ──")
TabAuth:Button("🚀 Launch Hub", "Verify and load the game script", function()
    if not isAccessAuthorized then
        Notify("Access Denied", "Enter a valid SlenderHub key first.", "Error", 4)
        return
    end
    if not GameModules[CurrentPlaceId] then
        Notify("Error", "Game not supported yet.", "Error", 3)
        return
